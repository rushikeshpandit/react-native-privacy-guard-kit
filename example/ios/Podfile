# example/ios/Podfile
require Pod::Executable.execute_command('node', ['-e',
  "process.stdout.write(require('path').dirname(require.resolve('react-native/package.json')))",
]).strip + '/scripts/react_native_pods'

require 'json'
podfile_properties = JSON.parse(File.read(File.join(__dir__, 'Podfile.properties.json'))) rescue {}

ENV['RCT_NEW_ARCH_ENABLED'] = podfile_properties['newArchEnabled'] == 'true' ? '1' : '0'

platform :ios, podfile_properties['ios.deploymentTarget'] || '15.1'

install! 'cocoapods', :deterministic_uuids => false

prepare_react_native_project!

target 'PrivacyGuardKitExample' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/..",
    :privacy_file_aggregation_enabled => podfile_properties['apple.privacyManifestAggregationEnabled'] != 'false',
  )

  # ── PrivacyGuardKit local pod ──────────────────────────────
  # The pod must be declared with the path so CocoaPods runs
  # its install_modules_dependencies hook, which triggers iOS
  # codegen to process the src/specs/ files.
  # pod 'PrivacyGuardKit', :path => '../../'

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )
  end
end
